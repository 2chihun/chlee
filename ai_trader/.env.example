# 한국투자증권 API 설정
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678-01

# 모드: paper(모의투자) / live(실전투자)
TRADING_MODE=paper

# 데이터베이스
DB_PATH=data/ai_trader.db

# 리스크 관리
MAX_POSITION_SIZE=2000000
MAX_DAILY_LOSS=-100000
MAX_POSITIONS=5
STOP_LOSS_PCT=-1.0
TAKE_PROFIT_PCT=2.0
